// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model RawPlayer {
  id       String  @id @unique
  username String  @default("Unknown")
  banned   Boolean @default(false)
  level    Int     @default(1)
  xp       Float     @default(0)
  money    Float   @default(0)
  gems     Float     @default(0)
  zoneId   Int     @default(1)

  skills RawPlayerSkill[]
  tasks  RawPlayerTask[]
  items  RawItem[]
  quests RawPlayerQuest[]
}

model RawPlayerSkill {
  playerId String
  type     Int

  level Int @default(1)
  xp    Int @default(0)

  player RawPlayer @relation(fields: [playerId], references: [id], onUpdate: Cascade, onDelete: Cascade)

  @@id([playerId, type])
}

model RawPlayerTask {
  playerId  String
  nodeId    Int
  startedAt DateTime

  player RawPlayer @relation(fields: [playerId], references: [id], onUpdate: Cascade, onDelete: Cascade)

  @@id([playerId, nodeId])
}

model RawItem {
  uuid       String           @id @unique @default(uuid())
  playerId   String
  itemId     Int
  upgrades   Int              @default(1)
  amount     Int
  locked     Boolean          @default(false)
  equipped   Boolean          @default(false)
  rarity     Int
  multiplier Float
  stats      RawItemStat[]
  passives   RawItemPassive[]

  player RawPlayer @relation(fields: [playerId], references: [id], onDelete: Cascade, onUpdate: Cascade)
}

model RawItemPassive {
  itemUUID  String
  passiveId Int

  item RawItem @relation(fields: [itemUUID], references: [uuid], onDelete: Cascade, onUpdate: Cascade)

  @@id([itemUUID, passiveId])
}

model RawPlayerQuest {
  uuid     String  @id @unique @default(uuid())
  playerId String
  questId  Int
  count    Int     @default(0)
  started  Boolean @default(false)

  player RawPlayer @relation(fields: [playerId], references: [id], onDelete: Cascade, onUpdate: Cascade)
}

model RawItemStat {
  uuid     String @id @unique @default(uuid())
  type     String
  value    Float
  itemUUID String

  item RawItem @relation(fields: [itemUUID], references: [uuid], onDelete: Cascade, onUpdate: Cascade)
}
